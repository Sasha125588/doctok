{
  "name": "doctok",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:fix:web": "bun run --cwd apps/web lint:fix",
    "fmt:web": "bun run --cwd apps/web fmt",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.9.4"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx,md,mdx,css,vue}": [
      "bun run lint:web",
      "bun run fmt:web"
    ]
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*"
  ]
}